{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Helium Docs",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "More Info",
          "icon": "lightbulb",
          "href": "https://tryhelium.com"
        }
      ]
    },
    "groups": [
      {
        "group": "Introduction",
        "icon": "flag",
        "pages": [
          "introduction/introduction",
          "introduction/quickstart"
        ]
      },
      {
        "group": "SDK Quickstarts",
        "icon": "code",
        "pages": [
          "sdk-quickstarts/overview",
          "sdk-quickstarts/i-os",
          "sdk-quickstarts/android",
          "sdk-quickstarts/react-native",
          "sdk-quickstarts/flutter",
          "sdk-quickstarts/feature-availability"
        ]
      },
      {
        "group": "Primitives",
        "icon": "cube",
        "pages": [
          {
            "group": "Paywalls",
            "pages": [
              "primitives/paywalls",
              "primitives/paywalls/localization",
              "sdk-quickstarts/fallbacks"
            ]
          },
          "primitives/workflows",
          "primitives/triggers",
          "primitives/experiments",
          "primitives/audiences",
          "primitives/product-buckets"
        ]
      },
      {
        "group": "Events",
        "icon": "chart-line",
        "pages": [
          "events/custom-paywall-events",
          "events/revenue-tracking"
        ]
      },
      {
        "group": "Analytics",
        "icon": "chart-bar",
        "pages": [
          "analytics/third-party-integrations"
        ]
      },
      {
        "group": "Migrations",
        "icon": "arrow-up-right-dots",
        "pages": [
          "migrations/overview",
          "migrations/ios-3-to-4",
          "migrations/android-0-to-4",
          "migrations/ios-2-to-3"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/LargeLogo-cropped.svg",
    "dark": "/logo/LargeLogo-cropped.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Schedule Demo",
      "href": "https://cal.com/team/helium/20-minute-helium-demo"
    }
  },
  "contextual": {
        "options": [
            "mcp",
            "cursor",
            "copy",
            "chatgpt",
            "claude"
        ]
    }
}
